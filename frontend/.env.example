# Supabase browser client
# Local Supabase: http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional. Frontend does not use this directly.
# Keep service-role secrets on the server / Edge Functions side only.
SUPABASE_SERVICE_ROLE_KEY=

# Google Gemini API
GEMINI_API_KEY=

# Upstash Redis（エンカウンターセッション管理）
# https://console.upstash.com/ で取得
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
